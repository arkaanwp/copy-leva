{
  "meta": {
    "title": "Kontrak API Leva — Dokumen Lengkap",
    "version": "1.1.0",
    "date": "2026-05-04",
    "base_url": "http://localhost:8000/api",
    "response_format": "JSON",
    "authentication": "Laravel Sanctum (Bearer Token)",
    "spec_reference": "Dokumen Konsep Dasar dan SRS Proyek Leva (IEEE 830-1998)"
  },
  "conventions": {
    "success_response": {
      "message": "Keterangan operasi",
      "data": {}
    },
    "validation_error_response": {
      "http_code": 422,
      "body": {
        "message": "The given data was invalid.",
        "errors": {
          "field_name": ["Pesan error spesifik."]
        }
      }
    },
    "user_status_enum": [
      { "value": "PENDING", "description": "Baru registrasi, belum menyelesaikan onboarding (profil kosong)" },
      { "value": "ACTIVE", "description": "Onboarding selesai — profil tersimpan ke Qdrant sebagai vector parameter" }
    ],
    "bookmark_priority_quadrant": [
      { "db_value": "must_try",  "ui_label": "Wajib Dicoba",        "description": "Fungsionalitas inti yang mengubah permainan untuk jurusan tersebut" },
      { "db_value": "very_good", "ui_label": "Sangat Bagus",        "description": "Efisiensi tinggi, direkomendasikan kuat" },
      { "db_value": "niche",     "ui_label": "Bagus/Niche",         "description": "Situasional atau untuk tugas spesifik" },
      { "db_value": "optional",  "ui_label": "Opsional/Alternatif", "description": "Duplikasi fungsional dari alat yang lebih kuat" }
    ]
  },
  "endpoints": {
    "auth": {
      "section": "A",
      "title": "Autentikasi",
      "routes": [
        {
          "id": "auth_register",
          "method": "POST",
          "path": "/api/auth/register",
          "name": "Registrasi Pengguna Baru",
          "feature": "Fondasi Sistem",
          "auth": "Public",
          "status": "PERLU_DIMODIFIKASI",
          "status_note": "Route saat ini: /api/register, perlu prefix /auth",
          "request_body": {
            "name": "string (maks 255 karakter)",
            "email": "string (format email valid, unik)",
            "password": "string (min 8 karakter)",
            "password_confirmation": "string"
          },
          "responses": {
            "201": {
              "message": "User registered successfully",
              "data": {
                "id": "uuid",
                "name": "Renisa Assyifa Putri",
                "email": "renisa@example.com",
                "status": "PENDING"
              }
            },
            "422_cases": [
              { "condition": "Email sudah terdaftar", "message": "The email has already been taken." },
              { "condition": "Password tidak cocok",  "message": "The password field confirmation does not match." }
            ]
          },
          "implementation_notes": [
            "Status user otomatis PENDING → user harus selesaikan onboarding (POST /api/profile) untuk akses dashboard",
            "Token belum diberikan saat registrasi — harus login dulu",
            "Data profil dari onboarding nantinya disimpan sebagai atribut vektor berparameter di Qdrant (REQ-F01)"
          ]
        },
        {
          "id": "auth_login",
          "method": "POST",
          "path": "/api/auth/login",
          "name": "Login dan Dapatkan Bearer Token",
          "auth": "Public",
          "status": "PERLU_DIMODIFIKASI",
          "status_note": "Route saat ini: /api/login",
          "request_body": {
            "email": "string",
            "password": "string"
          },
          "responses": {
            "200": {
              "message": "Login successful",
              "data": {
                "user": {
                  "id": "uuid",
                  "name": "Renisa Assyifa Putri",
                  "email": "renisa@example.com",
                  "status": "ACTIVE"
                },
                "token": "1|abc123tokenstring..."
              }
            },
            "error_cases": [
              { "http_code": 401, "condition": "Email/password salah",    "message": "Invalid credentials" },
              { "http_code": 422, "condition": "Field wajib kosong",      "message": "The email field is required." }
            ]
          },
          "implementation_notes": [
            "Cek status setelah login: jika PENDING → redirect ke onboarding; jika ACTIVE → redirect ke dashboard"
          ]
        },
        {
          "id": "auth_logout",
          "method": "POST",
          "path": "/api/auth/logout",
          "name": "Logout dan Cabut Token",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "responses": {
            "200": {
              "message": "Logged out successfully"
            }
          },
          "implementation_notes": [
            "Gunakan $request->user()->currentAccessToken()->delete() — hanya cabut token aktif saat ini",
            "Frontend hapus token dari localStorage dan redirect ke halaman login"
          ]
        },
        {
          "id": "auth_me",
          "method": "GET",
          "path": "/api/auth/me",
          "name": "Ambil Data User yang Sedang Login",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIMODIFIKASI",
          "status_note": "Route saat ini: /api/me",
          "responses": {
            "200": {
              "message": "Current user retrieved successfully",
              "data": {
                "user": {
                  "id": "uuid",
                  "name": "Renisa Assyifa Putri",
                  "email": "renisa@example.com",
                  "status": "ACTIVE",
                  "profile": {
                    "major": "Teknik Informatika",
                    "semester": 6,
                    "language_preference": "id",
                    "learning_style": "visual"
                  }
                }
              }
            }
          },
          "notes": [
            "Jika profil belum diisi (status: PENDING): field profile akan null"
          ]
        }
      ]
    },
    "profile": {
      "section": "B",
      "title": "Profil Pengguna",
      "req": "REQ-F01 (Profiling Kontekstual)",
      "spec_context": "Data profil (jurusan, semester, preferensi bahasa) disimpan sebagai atribut vektor berparameter dalam instance Qdrant untuk memfasilitasi operasi pemfilteran kueri secara real-time.",
      "routes": [
        {
          "id": "profile_create",
          "method": "POST",
          "path": "/api/profile",
          "name": "Buat Profil Kontekstual (Onboarding)",
          "feature": "REQ-F01",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIMODIFIKASI",
          "status_note": "Route saat ini: /api/onboarding",
          "request_body": {
            "major": "string (nama jurusan, maks 255 karakter)",
            "semester": "integer (1–14)",
            "language_preference": "id | en",
            "learning_style": "visual | auditory | kinesthetic"
          },
          "frontend_mismatch_note": "Frontend mengirim field jurusan (→ major) dan bahasa (→ language_preference). Perlu mapping di layer service frontend.",
          "responses": {
            "200": {
              "message": "Onboarding completed successfully",
              "data": {
                "user": {
                  "id": "uuid",
                  "name": "Renisa Assyifa Putri",
                  "email": "renisa@example.com",
                  "status": "ACTIVE",
                  "profile": {
                    "major": "Teknik Informatika",
                    "semester": 6,
                    "language_preference": "id",
                    "learning_style": "visual"
                  }
                }
              }
            },
            "error_cases": [
              { "http_code": 409, "condition": "Profil sudah pernah dibuat", "message": "User already completed onboarding." },
              { "http_code": 422, "condition": "Validasi gagal",             "message": "The major field is required." }
            ]
          },
          "implementation_notes": [
            "Setelah profil tersimpan ke MySQL, trigger async job untuk upsert profil ke Qdrant sebagai payload filter",
            "Status user berubah PENDING → ACTIVE dalam satu transaksi database"
          ]
        },
        {
          "id": "profile_get",
          "method": "GET",
          "path": "/api/profile",
          "name": "Ambil Profil Pengguna",
          "feature": "REQ-F01",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "responses": {
            "200": {
              "message": "Profile retrieved successfully",
              "data": {
                "profile": {
                  "id": "uuid",
                  "major": "Teknik Informatika",
                  "semester": 6,
                  "language_preference": "id",
                  "learning_style": "visual",
                  "updated_at": "2026-04-15T07:30:00Z"
                }
              }
            }
          }
        },
        {
          "id": "profile_update",
          "method": "PUT",
          "path": "/api/profile",
          "name": "Update Profil Pengguna",
          "feature": "REQ-F01",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "request_body_note": "Semua field opsional",
          "request_body": {
            "major": "string (opsional)",
            "semester": "integer (opsional)",
            "language_preference": "id | en (opsional)",
            "learning_style": "visual | auditory | kinesthetic (opsional)"
          },
          "implementation_notes": [
            "Jika major berubah, trigger job async untuk update payload filter di Qdrant",
            "Dipakai oleh ProfileView.jsx saat user menekan Simpan Perubahan"
          ]
        }
      ]
    },
    "tools": {
      "section": "C",
      "title": "Alat AI / Scraped Tools",
      "req": "REQ-F02 & REQ-F04",
      "routes": [
        {
          "id": "tools_list",
          "method": "GET",
          "path": "/api/tools",
          "name": "Ambil Daftar Alat AI",
          "feature": "REQ-F02 (data dari scraper), REQ-F04 (filter per profil)",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "query_parameters": [
            { "name": "page",     "type": "integer", "default": 1,  "description": "Nomor halaman" },
            { "name": "per_page", "type": "integer", "default": 12, "description": "Maks 50" },
            { "name": "category", "type": "string",  "default": null, "description": "Research | Writing | Coding | Data | Academic | Productivity" },
            { "name": "pricing",  "type": "string",  "default": null, "description": "free | freemium | paid | opensource" }
          ],
          "responses": {
            "200": {
              "message": "Tools retrieved successfully",
              "data": {
                "tools": [
                  {
                    "id": 1,
                    "name": "Perplexity AI",
                    "url": "perplexity.ai",
                    "description": "Mesin pencari berbasis AI dengan sumber terverifikasi.",
                    "category": "Research",
                    "pricing_type": "freemium",
                    "rating": 4.8,
                    "qdrant_uuid": "uuid-string"
                  }
                ],
                "pagination": {
                  "current_page": 1,
                  "per_page": 12,
                  "total": 12,
                  "last_page": 1
                }
              }
            }
          },
          "implementation_notes": [
            "Idealnya filter berdasarkan major user dari profil untuk personalisasi (Dashboard)",
            "Data diisi oleh Python scraper via webhook internal setiap 24 jam (REQ-F02)"
          ]
        },
        {
          "id": "tools_detail",
          "method": "GET",
          "path": "/api/tools/{id}",
          "name": "Detail Satu Alat AI",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "path_params": [
            { "name": "id", "type": "integer", "description": "ID tool dari MySQL" }
          ],
          "responses": {
            "200": {
              "message": "Tool retrieved successfully",
              "data": {
                "tool": {
                  "id": 1,
                  "name": "Perplexity AI",
                  "url": "perplexity.ai",
                  "description": "...",
                  "category": "Research",
                  "pricing_type": "freemium",
                  "rating": 4.8,
                  "qdrant_uuid": "uuid-string",
                  "scraped_at": "2026-05-04T00:00:00Z"
                }
              }
            }
          }
        },
        {
          "id": "tools_search",
          "method": "GET",
          "path": "/api/tools/search",
          "name": "Cari Alat AI via Hybrid Search Qdrant",
          "feature": "REQ-F04 — Rekomendasi Terkonteks",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "spec_context": "Sistem melakukan pencarian hibrida di Qdrant: dense vector similarity (cosine) + sparse vector filtering berdasarkan profil user (major, language). Skor relevansi minimum hasil teratas: 0.85 (REQ-F04).",
          "query_parameters": [
            { "name": "q",     "type": "string",  "required": true,  "description": "Query teks bebas dari user" },
            { "name": "limit", "type": "integer", "required": false, "description": "Default 5, maks 20" }
          ],
          "responses": {
            "200": {
              "message": "Search completed successfully",
              "data": {
                "query": "tools untuk literature review skripsi",
                "results": [
                  {
                    "id": 1,
                    "name": "Perplexity AI",
                    "url": "perplexity.ai",
                    "description": "Mesin pencari berbasis AI...",
                    "category": "Research",
                    "pricing_type": "freemium",
                    "score": 0.94,
                    "why_recommended": "Relevan untuk mahasiswa Teknik Informatika yang membutuhkan alat riset akademik terverifikasi."
                  }
                ]
              }
            },
            "error_cases": [
              { "http_code": 422, "condition": "Query kosong",           "message": "The q field is required." },
              { "http_code": 503, "condition": "Qdrant tidak tersedia",  "message": "Search service temporarily unavailable." }
            ]
          },
          "implementation_notes": [
            "Embed query menggunakan OpenAI text-embedding-3-small (dimensi 1536)",
            "Query ke koleksi Qdrant: tools_semantic_vectors",
            "Filter Qdrant: category_filter = kategori jurusan user (parameterized index)",
            "Fallback ke MySQL LIKE query jika Qdrant tidak tersedia (REQ-NF02: latency < 50ms)"
          ]
        }
      ]
    },
    "tasks": {
      "section": "D",
      "title": "Dekomposisi Tugas / PDF",
      "req": "REQ-F03",
      "spec_context": "LLM menggunakan paradigma KERNEL prompt engineering. Output JSON wajib berisi: judul_tugas, estimasi_waktu, kategori_alat_ai_yang_rekomendasi. PDF di-parse oleh spatie/pdf-to-text. Pemrosesan < 5 detik (REQ-F03).",
      "routes": [
        {
          "id": "tasks_submit",
          "method": "POST",
          "path": "/api/tasks",
          "name": "Submit Tugas untuk Dekomposisi Async",
          "feature": "REQ-F03",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "request_options": {
            "option_a_pdf": {
              "content_type": "multipart/form-data",
              "fields": {
                "pdf_file": "binary .pdf (maks 10MB)",
                "description": "string (opsional)"
              }
            },
            "option_b_text": {
              "content_type": "application/json",
              "fields": {
                "text": "string",
                "description": "string (opsional)"
              }
            }
          },
          "responses": {
            "202": {
              "message": "Task submitted for processing",
              "data": {
                "task_id": "uuid",
                "status": "processing",
                "estimated_seconds": 25,
                "poll_url": "/api/tasks/uuid/status"
              }
            }
          },
          "llm_output_schema": [
            {
              "judul_tugas": "Cari Topik",
              "estimasi_waktu": "1–2 hari",
              "kategori_alat_ai_yang_rekomendasi": "Research"
            }
          ],
          "implementation_notes": [
            "HTTP 202 (bukan 200) — proses async via Laravel Queue + Redis",
            "Job pipeline: ekstrak teks PDF (spatie/pdf-to-text) → chunk → LLM → parse JSON → query Qdrant per sub-task → simpan ke tasks_master + atomic_sub_tasks",
            "PDF disimpan sementara di tmpfs, dihapus otomatis setelah ekstraksi (REQ-NF03)",
            "Simpan source_pdf_hash (SHA-256) untuk deduplication"
          ]
        },
        {
          "id": "tasks_list",
          "method": "GET",
          "path": "/api/tasks",
          "name": "Daftar Semua Task Milik User",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "responses": {
            "200": {
              "message": "Tasks retrieved successfully",
              "data": {
                "tasks": [
                  {
                    "task_id": "uuid",
                    "title": "Menyusun Skripsi Teknik Informatika",
                    "status": "completed",
                    "sub_tasks_count": 5,
                    "completed_count": 2,
                    "source_type": "text",
                    "created_at": "2026-05-04T10:00:00Z"
                  }
                ],
                "pagination": {
                  "current_page": 1,
                  "total": 5,
                  "last_page": 1
                }
              }
            }
          }
        },
        {
          "id": "tasks_detail",
          "method": "GET",
          "path": "/api/tasks/{taskId}",
          "name": "Detail Task Beserta Sub-Tasks",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "path_params": [
            { "name": "taskId", "type": "uuid" }
          ],
          "responses": {
            "200": {
              "message": "Task retrieved successfully",
              "data": {
                "task": {
                  "task_id": "uuid",
                  "title": "Menyusun Skripsi Teknik Informatika",
                  "status": "completed",
                  "source_type": "text",
                  "created_at": "2026-05-04T10:00:00Z",
                  "sub_tasks": [
                    {
                      "sub_task_id": "uuid",
                      "actionable_title": "Cari Topik",
                      "description": "Langkah pertama dan sangat krusial...",
                      "tips": "Gunakan Perplexity AI untuk riset cepat...",
                      "status": "done",
                      "category": "Research",
                      "estimated_duration": "1–2 hari",
                      "order": 1,
                      "recommended_tools": [
                        {
                          "id": 1,
                          "name": "Perplexity AI",
                          "url": "perplexity.ai",
                          "category": "Research"
                        }
                      ]
                    }
                  ]
                }
              }
            }
          }
        },
        {
          "id": "subtask_update_status",
          "method": "PATCH",
          "path": "/api/tasks/{taskId}/sub-tasks/{subTaskId}",
          "name": "Update Status Sub-Task",
          "feature": "REQ-F03 (Atomic Habits — loop kebiasaan)",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "path_params": [
            { "name": "taskId",    "type": "uuid" },
            { "name": "subTaskId", "type": "uuid" }
          ],
          "request_body": {
            "status": "done | next"
          },
          "responses": {
            "200": {
              "message": "Sub-task updated successfully",
              "data": {
                "sub_task": {
                  "sub_task_id": "uuid",
                  "actionable_title": "Cari Topik",
                  "status": "done"
                }
              }
            }
          }
        },
        {
          "id": "tasks_delete",
          "method": "DELETE",
          "path": "/api/tasks/{taskId}",
          "name": "Hapus Task Beserta Sub-Tasks",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "path_params": [
            { "name": "taskId", "type": "uuid" }
          ],
          "responses": {
            "200": {
              "message": "Task deleted successfully"
            }
          }
        },
        {
          "id": "tasks_poll_status",
          "method": "GET",
          "path": "/api/tasks/{taskId}/status",
          "name": "Polling Status Pemrosesan Task Async",
          "feature": "REQ-F03 (fallback polling jika WebSocket belum aktif)",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "path_params": [
            { "name": "taskId", "type": "uuid" }
          ],
          "responses": {
            "200": {
              "message": "Task status retrieved",
              "data": {
                "task_id": "uuid",
                "status": "completed",
                "progress_message": "Sub-tasks berhasil dibuat",
                "sub_tasks_count": 5,
                "ready": true
              }
            }
          },
          "status_enum": [
            { "value": "processing", "description": "Job sedang berjalan di queue" },
            { "value": "completed",  "description": "Dekomposisi selesai" },
            { "value": "failed",     "description": "Gagal — sertakan error_message" }
          ],
          "implementation_notes": [
            "Frontend polling setiap 2 detik",
            "Alternatif: WebSocket via Laravel Broadcasting (event TaskCompleted, channel private-user.{userId})"
          ]
        }
      ]
    },
    "chat": {
      "section": "E",
      "title": "Rekomendasi Chat / RAG",
      "req": "REQ-F04",
      "spec_context": "Sistem menggunakan Agentic RAG. LLM hanya boleh mensintesis respons dari data yang disuntikkan dari Qdrant — dilarang keras membuat rekomendasi yang tidak ada di database (anti-halusinasi).",
      "routes": [
        {
          "id": "chat_send",
          "method": "POST",
          "path": "/api/chat",
          "name": "Kirim Pesan dan Dapatkan Respons RAG",
          "feature": "REQ-F04",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "request_body": {
            "message": "string",
            "context_task_id": "uuid (opsional — link ke task yang sedang aktif)"
          },
          "responses": {
            "200": {
              "message": "Chat response generated",
              "data": {
                "reply": "Untuk analisis data statistik, saya rekomendasikan Julius AI karena kemampuannya menganalisis spreadsheet dengan bahasa natural...",
                "recommended_tools": [
                  {
                    "id": 4,
                    "name": "Julius AI",
                    "url": "julius.ai",
                    "description": "Analisis data dengan bahasa natural.",
                    "category": "Data",
                    "pricing_type": "freemium",
                    "score": 0.95
                  }
                ],
                "conversation_id": "uuid"
              }
            }
          },
          "rag_pipeline": [
            "1. Embed query user → vektor 1536 dimensi (OpenAI text-embedding-3-small)",
            "2. Hybrid search Qdrant collection tools_semantic_vectors",
            "3. Filter parametrik: category_filter sesuai major user",
            "4. Ambil 3–5 entri skor tertinggi (min score 0.85 per REQ-F04)",
            "5. Suntikkan ke prompt LLM sebagai konteks",
            "6. Simpan conversation + messages ke DB"
          ],
          "implementation_notes": [
            "Terapkan throttle:30,1 untuk endpoint ini (cegah abuse ke API LLM)"
          ]
        },
        {
          "id": "chat_history",
          "method": "GET",
          "path": "/api/chat/history",
          "name": "Ambil Riwayat Percakapan",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "responses": {
            "200": {
              "message": "Chat history retrieved successfully",
              "data": {
                "conversations": [
                  {
                    "id": "uuid",
