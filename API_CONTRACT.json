                  }
                ],
                "pagination": {
                  "current_page": 1,
                  "total": 5,
                  "last_page": 1
                }
              }
            }
          }
        },
        {
          "id": "chat_history_delete",
          "method": "DELETE",
          "path": "/api/chat/history",
          "name": "Hapus Semua Riwayat Chat",
          "auth": "Bearer Token (Sanctum)",
          "status": "PERLU_DIBUAT",
          "responses": {
            "200": {
              "message": "Chat history cleared successfully"
            }
          }
        }
      ]
    },
    "bookmarks": {
      "section": "F",
